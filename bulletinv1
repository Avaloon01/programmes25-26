        ["S16","Distinguer les différents types de triangles et leurs caractéristiques (angles, côtés)."],
        ["S17","Tracer une diagonale dans un rectangle ou un carré et reconnaître ses propriétés."],
        ["S18","Tracer les diagonales d'un carré ou d'un rectangle et observer qu'elles se coupent en leur milieu."],
      ]},
      { champ: "Algèbre et arithmétique — Numération", attendus: [
        ["S3","Dire, lire, écrire les nombres ≤ 100 000 ; utiliser unités/dizaines/centaines/milliers."],
        ["S4","Représenter/écrire en numération décimale (abaque, classes)."],
        ["S5","Décomposer et recomposer des nombres (3 à 6 chiffres)."],
        ["S6","Comparer/ordonner des nombres (signes <, >, =)."],
        ["S7","Compter par 100, 200, 500, 1 000 ; repérer une régularité."],
        ["S8","Compter par 100, 200, 500, 1 000 ; déterminer la régularité d'une suite numérique."],
        ["S9","Compléter ou prolonger des suites en respectant une régularité donnée."],
      ]},
      { champ: "Algèbre et arithmétique — Calcul mental", attendus: [
        ["S1","Effectuer des additions mentales simples et estimer un résultat."],
        ["S2","Effectuer des soustractions simples et vérifier le résultat."],
        ["S3","Utiliser la commutativité et la décomposition pour le calcul mental."],
        ["S4","Appliquer les tables de multiplication simples."],
        ["S5","Identifier les régularités et les liens entre tables."],
        ["S6","Utiliser la relation multiplication ⇄ division pour vérifier un calcul."],
        ["S7","Identifier l'opération adéquate selon le contexte."],
        ["S8","Utiliser la valeur positionnelle des chiffres dans un nombre."],
        ["S9","Comprendre le système décimal et les décalages de rangs (×/÷ 10, 100, 1000)."],
        ["S10","Identifier les régularités et liens entre tables (T2, T4, T8)."],
        ["S11","Identifier les régularités et liens entre tables (T3, T6, T9)."],
      ]},
      { champ: "Algèbre et arithmétique — Calcul écrit", attendus: [
        ["S10","Placer les nombres afin de réaliser une multiplication écrite."],
