    ]
  },
  {
    domaine: "PECA",
    champs: [
      { champ: "Arts & culture", attendus: [
        ["S1","Relier une région à un style de musique."],
        ["S2","Associer une période à un style de musique."],
        ["S3","Se représenter et parler de soi à travers une musique."],
        ["S4","Découper et coller en respectant la symétrie."],
        ["S5","Réaliser un mobile en utilisant le vocabulaire : équilibre stable, instable, déséquilibre."],
        ["S6","Faire le lien entre l'art contemporain, le cirque et la recherche de l'équilibre."],
        ["S7","Repérer des œuvres du pop art."],
