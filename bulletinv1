        ["S13","Placer les nombres afin de réaliser une division écrite."],
        ["S14","Réaliser une division écrite avec 3 chiffres dans le dividende."],
      ]},
      { champ: "Grandeurs", attendus: [
        ["S5","Maîtriser le vocabulaire des longueurs ; comparer et classer."],
        ["S6","Mesurer avec la règle (cm, mm) et indiquer l'unité."],
        ["S7","Choisir une unité pertinente pour estimer puis mesurer."],
        ["S8","Calculer le périmètre d'un rectangle et d'un carré."],
        ["S9","Calculer le périmètre d'une forme quelconque."],
        ["S10","Utiliser l'échelle pour réaliser une réduction."],
        ["S11","Mesurer l'aire d'un carré."],
        ["S12","Mesurer l'aire d'un rectangle."],
      ]},
      { champ: "Traitement de données", attendus: [
        ["S5","Lire un tableau à une entrée et prélever les informations."],
        ["S6","Compléter un tableau simple avec des données."],
        ["S7","Calculer un total et comparer des valeurs dans un tableau."],
        ["S8","Se poser une question qui mènera à une collecte de données."],
        ["S9","Écrire des questions afin de collecter des données via questionnaire."],
        ["S10","Nommer des catégories."],
        ["S11","Classer les données dans des catégories et les présenter."],
        ["S12","Conclure grâce aux données."],
        ["S13","Retrouver les données pour effectuer une proportionnalité."],
        ["S14","Tracer un tableau et nommer deux catégories (règle de trois)."],
        ["S15","Placer les éléments connus dans un tableau (règle de trois)."],
        ["S16","Trouver le lien qui unit deux grandeurs (direct)."],
        ["S17","Trouver le lien qui unit deux grandeurs (en passant par 1)."],
        ["S18","Trouver le lien qui unit deux grandeurs (autre que 1)."],
      ]},
    ]
  },
  {
    domaine: "Français",
    champs: [
      { champ: "Produire un écrit", attendus: [
        ["S1","Copier sans erreur une phrase courte en respectant la présentation."],
        ["S2","Écrire une phrase complète lisiblement avec majuscule et point."],
        ["S3","Produire un écrit court en respectant la consigne."],
        ["S4","Rédiger 3 à 4 phrases cohérentes sur un sujet connu."],
        ["S5","Utiliser la ponctuation (. ? !) correctement dans une production."],
        ["S6","Utiliser le code CHAMPION pour se corriger."],
        ["S7","Planifier son récit en identifiant QUI ? QUAND ? OÙ ? QUOI ? LA FIN ?"],
        ["S8","Écrire son texte — le début."],
        ["S9","Écrire son texte — le problème et les actions."],
        ["S10","Écrire son texte — la fin."],
        ["S11","Utiliser le dictionnaire de manière autonome."],
        ["S12","Organiser ses idées de manière logique."],
        ["S13","Accorder correctement les mots les plus fréquents au pluriel."],
        ["S14","Répondre à une question en mobilisant les éléments de la question."],
        ["S15","Identifier le verbe conjugué / le verbe à l'infinitif."],
        ["S16","Résumer un album jeunesse."],
        ["S17","Utiliser les homophones (a/à)."],
        ["S18","Utiliser les homophones (c'est/ces/ses/s'est)."],
