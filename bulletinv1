<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bulletin P4 — FWB</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f4f2ee;
  --surface: #ffffff;
  --ink: #1a1814;
  --ink2: #6b6660;
  --ink3: #a8a39e;
  --accent: #2d5a3d;
  --gold: #c8973a;
  --red: #8b3a3a;
  --amber: #9a6e1a;
  --green: #2d5a3d;
  --border: #e0ddd6;
  --radius: 12px;
  --d1: #2d5a3d;
  --d2: #3a4a6b;
  --d3: #6b3a2d;
  --d4: #4a3a6b;
  --d5: #3a5a6b;
  --transition: 0.2s cubic-bezier(0.4,0,0.2,1);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--ink); min-height: 100vh; font-size: 15px; line-height: 1.6; }
.app { display: grid; grid-template-columns: 240px 1fr; min-height: 100vh; }
.sidebar { background: var(--ink); color: #f4f2ee; display: flex; flex-direction: column; position: sticky; top: 0; height: 100vh; overflow-y: auto; }
.sidebar-header { padding: 24px 18px 16px; border-bottom: 1px solid rgba(255,255,255,0.08); }
.sidebar-logo { font-family: 'DM Serif Display', serif; font-size: 19px; margin-bottom: 3px; color: #f4f2ee; }
.sidebar-sub { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(244,242,238,0.4); font-weight: 500; }
.sidebar-label { padding: 16px 18px 6px; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(244,242,238,0.35); font-weight: 600; }
.eleve-btn { display: flex; align-items: center; gap: 8px; padding: 7px 18px; cursor: pointer; border: none; background: none; color: rgba(244,242,238,0.65); width: 100%; text-align: left; font-family: 'DM Sans', sans-serif; font-size: 13px; transition: all var(--transition); }
.eleve-btn:hover { background: rgba(255,255,255,0.07); color: #f4f2ee; }
.eleve-btn.active { background: rgba(255,255,255,0.12); color: #f4f2ee; font-weight: 500; }
.eleve-btn.active .eleve-dot { background: var(--gold); }
.eleve-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.18); flex-shrink: 0; transition: background var(--transition); }
.eleve-mini { margin-left: auto; font-size: 10px; color: rgba(244,242,238,0.35); font-variant-numeric: tabular-nums; }
.main { display: flex; flex-direction: column; min-height: 100vh; }
.topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 28px; height: 60px; display: flex; align-items: center; gap: 12px; position: sticky; top: 0; z-index: 100; }
.topbar-name { font-family: 'DM Serif Display', serif; font-size: 21px; color: var(--ink); flex: 1; }
.topbar-score { font-size: 12px; color: var(--ink2); background: var(--bg); padding: 5px 12px; border-radius: 20px; border: 1px solid var(--border); font-variant-numeric: tabular-nums; }
.topbar-score strong { color: var(--accent); }
.filter-pills { display: flex; gap: 5px; }
.pill { font-size: 12px; padding: 4px 11px; border-radius: 20px; border: 1px solid var(--border); background: var(--surface); color: var(--ink2); cursor: pointer; transition: all var(--transition); font-family: 'DM Sans', sans-serif; }
.pill:hover { border-color: var(--accent); color: var(--accent); }
.pill.active { background: var(--ink); color: #f4f2ee; border-color: var(--ink); }
.btn-export { display: flex; align-items: center; gap: 5px; font-size: 12px; padding: 6px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink2); cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all var(--transition); font-weight: 500; }
.btn-export:hover { background: var(--ink); color: #f4f2ee; border-color: var(--ink); }
.saving-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--gold); animation: pulse 1s ease infinite; display: none; }
.saving-dot.visible { display: block; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
.content { padding: 24px 28px; flex: 1; }
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 60vh; text-align: center; color: var(--ink3); }
.empty-state h3 { font-family: 'DM Serif Display', serif; font-size: 20px; color: var(--ink2); margin: 12px 0 6px; }
.empty-state p { font-size: 13px; }
.domaine-block { margin-bottom: 24px; }
.domaine-header { display: flex; align-items: center; gap: 10px; padding: 12px 16px; border-radius: var(--radius) var(--radius) 0 0; cursor: pointer; user-select: none; color: #fff; transition: filter var(--transition); }
.domaine-header:hover { filter: brightness(1.08); }
.domaine-header.d0 { background: var(--d1); }
.domaine-header.d1 { background: var(--d2); }
.domaine-header.d2 { background: var(--d3); }
.domaine-header.d3 { background: var(--d4); }
.domaine-header.d4 { background: var(--d5); }
.domaine-title { font-family: 'DM Serif Display', serif; font-size: 15px; flex: 1; }
.domaine-stats { font-size: 11px; opacity: 0.7; font-variant-numeric: tabular-nums; }
.domaine-chevron { font-size: 10px; opacity: 0.6; transition: transform var(--transition); }
.domaine-chevron.open { transform: rotate(90deg); }
.domaine-body { border: 1px solid var(--border); border-top: none; border-radius: 0 0 var(--radius) var(--radius); overflow: hidden; background: var(--surface); }
.prog-wrap { display: flex; align-items: center; gap: 8px; min-width: 100px; }
.prog-bar { flex: 1; height: 3px; background: rgba(255,255,255,0.2); border-radius: 2px; }
.prog-fill { height: 100%; border-radius: 2px; background: rgba(255,255,255,0.65); transition: width 0.4s ease; }
.champ-block { border-top: 1px solid var(--border); }
.champ-block:first-child { border-top: none; }
.champ-header { display: flex; align-items: center; gap: 8px; padding: 9px 16px; background: #faf9f7; cursor: pointer; user-select: none; transition: background var(--transition); }
.champ-header:hover { background: #f2f0eb; }
.champ-title { font-size: 12px; font-weight: 600; color: var(--ink); flex: 1; letter-spacing: -0.05px; }
.champ-stats { font-size: 10px; color: var(--ink3); }
.champ-chevron { font-size: 9px; color: var(--ink3); transition: transform var(--transition); }
.champ-chevron.open { transform: rotate(90deg); }
.attendus-table { width: 100%; border-collapse: collapse; }
.attendus-table th { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink3); padding: 7px 16px; text-align: left; background: #fdfcfb; border-bottom: 1px solid var(--border); }
.attendus-table th:last-child { text-align: center; }
.attendu-row { border-bottom: 1px solid #f0eee8; transition: background var(--transition); }
.attendu-row:last-child { border-bottom: none; }
.attendu-row:hover { background: #faf8f5; }
.attendu-row.acquis { opacity: 0.45; }
.attendu-row td { padding: 9px 16px; vertical-align: middle; }
.sem-badge { font-size: 10px; font-weight: 600; color: var(--ink3); background: var(--bg); padding: 2px 6px; border-radius: 4px; white-space: nowrap; }
.attendu-text { font-size: 12px; color: var(--ink); line-height: 1.5; }
.score-group { display: flex; gap: 3px; justify-content: center; white-space: nowrap; }
.sbtn { width: 30px; height: 30px; border-radius: 7px; border: 1.5px solid var(--border); background: var(--bg); font-size: 12px; font-weight: 600; cursor: pointer; color: var(--ink3); font-family: 'DM Sans', sans-serif; transition: all var(--transition); display: flex; align-items: center; justify-content: center; }
.sbtn:hover { transform: translateY(-1px); box-shadow: 0 3px 8px rgba(0,0,0,0.1); }
.sbtn.s0.active { background: #fde8e8; border-color: #c97070; color: var(--red); }
.sbtn.s1.active { background: #fff3cc; border-color: #d4a840; color: var(--amber); }
.sbtn.s2.active { background: #d6f0d6; border-color: #5ca05c; color: var(--green); }
.toast { position: fixed; bottom: 20px; right: 20px; background: var(--ink); color: #f4f2ee; padding: 9px 16px; border-radius: 9px; font-size: 13px; font-weight: 500; transform: translateY(60px); opacity: 0; transition: all 0.28s cubic-bezier(0.34,1.56,0.64,1); pointer-events: none; z-index: 999; }
.toast.show { transform: translateY(0); opacity: 1; }
@media (max-width: 760px) {
  .app { grid-template-columns: 1fr; }
  .sidebar { height: auto; position: relative; }
  .topbar { padding: 8px 14px; flex-wrap: wrap; height: auto; gap: 6px; }
  .content { padding: 14px; }
}
</style>
</head>
<body>
<div class="app">
  <aside class="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo">Bulletin P4</div>
      <div class="sidebar-sub">Fédération Wallonie-Bruxelles</div>
    </div>
    <div class="sidebar-label">Élèves</div>
    <div id="eleve-list"></div>
  </aside>
  <main class="main">
    <div class="topbar">
      <div class="topbar-name" id="topbar-name">Sélectionne un élève</div>
      <div class="saving-dot" id="saving-dot"></div>
      <div class="topbar-score" id="topbar-score" style="display:none"></div>
      <div class="filter-pills" id="filter-pills" style="display:none">
        <button class="pill active" data-f="all">Tout</button>
        <button class="pill" data-f="non-acquis">Non acquis</button>
        <button class="pill" data-f="acquis">Acquis</button>
      </div>
      <button class="btn-export" id="btn-export" style="display:none" onclick="exporterCSV()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        CSV
      </button>
    </div>
    <div class="content" id="content">
      <div class="empty-state">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        <h3>Aucun élève sélectionné</h3>
        <p>Choisis un élève dans le panneau de gauche.</p>
      </div>
    </div>
  </main>
</div>
<div class="toast" id="toast"></div>

<script>
const APPS_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbxUAUjaOoOJfOetc22HE2HkC7buNyBiskAhgGfYfjsRZE3a3gycSBaPO3opWSKfmniIGQ/exec";

const ELEVES = [
  "Issa","Alaa","Fadl","Soufiane","Amir","Laetitia","Makram",
  "Wissal","Malak","Amira","Lina","Safae","Jana","Oumnia",
  "Anas","Salim","Thomas","Warda","Salmane","Aïssata","Tristian"
];

const BULLETIN = [
  {
    domaine: "Mathématiques",
    champs: [
      { champ: "Géométrie", attendus: [
        ["S2","Identifier points, segments, droites, demi-droites, angles droits ; utiliser le vocabulaire."],
        ["S3","Tracer et comparer des segments à la latte ; exprimer longueur et nom."],
        ["S4","Tracer des perpendiculaires avec l'équerre."],
        ["S5","Réinvestir segments + perpendiculaires dans des figures simples."],
        ["S6","Tracer des parallèles ; reconnaître le symbole //."],
        ["S7","Tracer un rectangle ; identifier côtés parallèles et perpendiculaires."],
        ["S9","Tracer un carré à partir d'un côté donné ; reconnaître les propriétés d'égalité des côtés et d'angles droits."],
        ["S10","Tracer un parallélogramme en utilisant la notion de parallélisme ; identifier les côtés opposés."],
        ["S12","Identifier l'angle droit et tracer un triangle rectangle."],
        ["S13","Construire un triangle possédant deux côtés isométriques."],
        ["S14","Construire un triangle dont les trois côtés sont égaux ; reconnaître la régularité."],
