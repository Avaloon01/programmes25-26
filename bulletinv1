        ["S2","Repérer le début, le problème et la fin d'un récit."],
        ["S3","Suivre correctement une consigne comportant plusieurs actions."],
        ["S4","Souligner ou relever les réponses directement dans le texte."],
        ["S6","Décrire un personnage et ses émotions."],
        ["S7","Identifier les indices de lieu et de temps."],
        ["S8","Repérer les informations explicites dans un texte court."],
        ["S9","Lire un texte avec une vitesse adaptée en respectant la ponctuation et l'expressivité."],
        ["S10","Lire à voix haute avec assurance et une bonne intonation."],
        ["S11","Comprendre le sens global d'un texte."],
        ["S12","Repérer les informations implicites dans un texte."],
        ["S13","Distinguer les principaux types de textes."],
        ["S14","Reconnaître les caractéristiques d'un texte narratif."],
        ["S15","Lire à voix haute un album jeunesse en mettant du cœur et de l'expressivité."],
      ]},
      { champ: "Savoir s'exprimer oralement", attendus: [
        ["S1","Dire son prénom, quelques goûts, en regardant l'auditoire."],
        ["S2","Présenter quelqu'un en phrases simples et complètes."],
        ["S4","Parler distinctement et à un volume adapté au lieu."],
        ["S5","Employer les formules de politesse et attendre son tour."],
        ["S6","Employer un vocabulaire précis pour décrire un objet."],
      ]},
    ]
  },
  {
    domaine: "Éveil scientifique & sciences humaines",
    champs: [
      { champ: "Éveil scientifique", attendus: [
        ["S2","Distinguer vivant / non-vivant et justifier."],
        ["S3","Comprendre la notion de cycle."],
        ["S4","Décrire le cycle de l'eau."],
        ["S5","Présenter un message pour expliquer comment l'eau se répartit sur terre."],
        ["S10","Citer les besoins du corps pour être en forme."],
