        ["S6","Associer une date à son siècle et à son millénaire."],
        ["S7","Citer les périodes conventionnelles de l'histoire."],
        ["S8","Collaborer pour présenter un thème durant une période historique."],
        ["S9","Situer des personnages, lieux et moments dans le temps."],
      ]},
      { champ: "Géographie", attendus: [
        ["S4","Écrire le vocabulaire des directions."],
        ["S5","Indiquer N-E-S-O sur une rose des vents."],
