// Générer IDs uniques
let gid = 0;
BULLETIN.forEach(d => d.champs.forEach(c => c.attendus.forEach(a => { a.push('a'+(++gid)); })));

// ── STATE ──
let currentEleve = null;
let scores = {};
let filter = 'all';
let openDom = {};
let openCh = {};
let saveTimer = null;

function init() {
  // Charger localStorage
  try { const r = localStorage.getItem('bul_p4_v3'); if (r) scores = JSON.parse(r); } catch(e) {}
  renderSidebar();
  setupFilters();
  updateAllMinis();
}

function sid(s) { return s.replace(/[^a-zA-Z0-9]/g,'_'); }

function renderSidebar() {
  const list = document.getElementById('eleve-list');
  list.innerHTML = '';
  ELEVES.forEach(e => {
    const btn = document.createElement('button');
    btn.className = 'eleve-btn';
    btn.dataset.eleve = e;
    btn.innerHTML = `<span class="eleve-dot"></span><span>${e}</span><span class="eleve-mini" id="mini-${sid(e)}"></span>`;
    btn.onclick = () => selectEleve(e);
    list.appendChild(btn);
  });
}

function setupFilters() {
  document.querySelectorAll('.pill').forEach(p => {
    p.onclick = () => {
      filter = p.dataset.f;
      document.querySelectorAll('.pill').forEach(x => x.classList.remove('active'));
      p.classList.add('active');
      renderBulletin();
    };
  });
}

async function selectEleve(e) {
  currentEleve = e;
  document.querySelectorAll('.eleve-btn').forEach(b => b.classList.toggle('active', b.dataset.eleve === e));
  document.getElementById('topbar-name').textContent = e;
  ['topbar-score','filter-pills','btn-export'].forEach(id => document.getElementById(id).style.display = '');
  renderBulletin();
  // Charger depuis Sheets
  try {
    const url = APPS_SCRIPT_URL + '?action=get&eleve=' + encodeURIComponent(e);
    const resp = await fetch(url);
    const data = await resp.json();
    if (data && data.scores) {
      if (!scores[e]) scores[e] = {};
      Object.assign(scores[e], data.scores);
      saveLocal();
      renderBulletin();
      updateMini(e);
    }
  } catch(err) { console.warn('Mode local', err); }
}

function getScore(id) { return scores[currentEleve]?.[id] ?? -1; }

function setScore(id, val) {
  if (!currentEleve) return;
  if (!scores[currentEleve]) scores[currentEleve] = {};
  if (scores[currentEleve][id] === val) delete scores[currentEleve][id];
  else scores[currentEleve][id] = val;
  saveLocal();
  scheduleSave();
  renderBulletin();
}

function saveLocal() {
  try { localStorage.setItem('bul_p4_v3', JSON.stringify(scores)); } catch(e) {}
}

function scheduleSave() {
  if (saveTimer) clearTimeout(saveTimer);
  saveTimer = setTimeout(async () => {
    if (!currentEleve) return;
    document.getElementById('saving-dot').classList.add('visible');
    try {
      await fetch(APPS_SCRIPT_URL, {
        method: 'POST', mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'set', eleve: currentEleve, scores: scores[currentEleve] || {} })
      });
      showToast('Sauvegardé ✓');
    } catch(e) { showToast('Sauvegardé localement'); }
    document.getElementById('saving-dot').classList.remove('visible');
  }, 1200);
}

function getDomStats(dom) {
  let pts = 0, total = 0;
  dom.champs.forEach(c => c.attendus.forEach(a => { total++; const s = getScore(a[2]); if (s >= 0) pts += s; }));
  return { pts, total };
}

function getAllStats() {
  let pts = 0, total = 0;
  BULLETIN.forEach(d => d.champs.forEach(c => c.attendus.forEach(a => { total++; const s = getScore(a[2]); if (s >= 0) pts += s; })));
  return { pts, max: total * 2, pct: Math.round((pts / (total * 2)) * 100) };
}

function updateMini(e) {
  const el = document.getElementById('mini-' + sid(e));
  if (!el) return;
  const prev = currentEleve; currentEleve = e;
  const { pts, max } = getAllStats();
  currentEleve = prev;
  el.textContent = pts + '/' + max;
}

function updateAllMinis() { ELEVES.forEach(e => updateMini(e)); }

function renderBulletin() {
  if (!currentEleve) return;
  const content = document.getElementById('content');
  content.innerHTML = '';
  BULLETIN.forEach((dom, di) => content.appendChild(renderDomaine(dom, di)));
  const { pts, max, pct } = getAllStats();
  document.getElementById('topbar-score').innerHTML = `<strong>${pts}</strong> / ${max} pts — ${pct}%`;
  updateMini(currentEleve);
}

function renderDomaine(dom, di) {
  const isOpen = openDom[di] !== false;
  const { pts, total } = getDomStats(dom);
  const pct = total > 0 ? Math.round((pts / (total * 2)) * 100) : 0;
  const wrap = document.createElement('div');
  wrap.className = 'domaine-block';
  const hdr = document.createElement('div');
  hdr.className = `domaine-header d${di}`;
  hdr.innerHTML = `<span class="domaine-chevron ${isOpen?'open':''}">▶</span>
    <span class="domaine-title">${dom.domaine}</span>
    <div class="prog-wrap"><div class="prog-bar"><div class="prog-fill" style="width:${pct}%"></div></div>
    <span class="domaine-stats">${pts}/${total*2}</span></div>`;
  hdr.onclick = () => { openDom[di] = !isOpen; renderBulletin(); };
  wrap.appendChild(hdr);
  if (isOpen) {
    const body = document.createElement('div');
    body.className = 'domaine-body';
    dom.champs.forEach((ch, ci) => body.appendChild(renderChamp(ch, `${di}_${ci}`)));
    wrap.appendChild(body);
  }
  return wrap;
}

function renderChamp(ch, key) {
  const isOpen = openCh[key] !== false;
  const acq = ch.attendus.filter(a => getScore(a[2]) === 2).length;
  const wrap = document.createElement('div');
  wrap.className = 'champ-block';
  const hdr = document.createElement('div');
  hdr.className = 'champ-header';
  hdr.innerHTML = `<span class="champ-chevron ${isOpen?'open':''}">▶</span>
    <span class="champ-title">${ch.champ}</span>
    <span class="champ-stats">${acq}/${ch.attendus.length} acquis</span>`;
  hdr.onclick = () => { openCh[key] = !isOpen; renderBulletin(); };
  wrap.appendChild(hdr);
  if (!isOpen) return wrap;
  const table = document.createElement('table');
  table.className = 'attendus-table';
  table.innerHTML = `<thead><tr><th style="width:52px">Sem.</th><th>Attendu</th><th style="width:120px;text-align:center">Évaluation</th></tr></thead>`;
  const tbody = document.createElement('tbody');
  let hasRows = false;
  ch.attendus.forEach(a => {
    const [sem, texte, id] = a;
    const sc = getScore(id);
    const isAcquis = sc === 2;
    if (filter === 'acquis' && !isAcquis) return;
    if (filter === 'non-acquis' && isAcquis) return;
    hasRows = true;
    const tr = document.createElement('tr');
    tr.className = 'attendu-row' + (isAcquis ? ' acquis' : '');
    tr.innerHTML = `<td><span class="sem-badge">${sem}</span></td>
      <td><span class="attendu-text">${texte}</span></td>
      <td><div class="score-group">
        <button class="sbtn s0 ${sc===0?'active':''}" onclick="setScore('${id}',0)">0</button>
        <button class="sbtn s1 ${sc===1?'active':''}" onclick="setScore('${id}',1)">1</button>
        <button class="sbtn s2 ${sc===2?'active':''}" onclick="setScore('${id}',2)">2</button>
      </div></td>`;
    tbody.appendChild(tr);
  });
  if (!hasRows) {
    const tr = document.createElement('tr');
    tr.innerHTML = `<td colspan="3" style="text-align:center;padding:12px;font-size:12px;color:var(--ink3)">Aucun attendu dans ce filtre.</td>`;
    tbody.appendChild(tr);
  }
  table.appendChild(tbody);
  wrap.appendChild(table);
  return wrap;
}

function exporterCSV() {
  if (!currentEleve) return;
  const rows = [['Prénom','Domaine','Champ','Semaine','Attendu','Score','Statut']];
  BULLETIN.forEach(d => d.champs.forEach(c => c.attendus.forEach(a => {
    const [sem, texte, id] = a;
    const sc = scores[currentEleve]?.[id];
    const statut = sc === 2 ? 'Acquis' : sc === 1 ? 'En voie' : sc === 0 ? 'Non acquis' : 'Non évalué';
    rows.push([currentEleve, d.domaine, c.champ, sem, texte, sc !== undefined ? sc : '', statut]);
  })));
  const csv = rows.map(r => r.map(c => `"${String(c).replace(/"/g,'""')}"`).join(',')).join('\n');
  const blob = new Blob(['\uFEFF'+csv], {type:'text/csv;charset=utf-8;'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = `bulletin_${currentEleve}.csv`; a.click();
  URL.revokeObjectURL(url);
  showToast('Export téléchargé ✓');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2000);
}

init();
</script>
</body>
</html>
